// cachingRepository wraps a {{ .ModuleName }}Repository with Redis caching.
// Implements the Decorator pattern — the use case only sees {{ .ModuleName }}Repository.
type cachingRepository struct {
	inner  portOutbound.{{ .ModuleName }}Repository
	client *redis.Client
	ttl    time.Duration
}

// NewCachingRepository wraps the given repository with Redis caching.
// Pass nil client to disable caching (falls through to inner repository).
func NewCachingRepository(inner portOutbound.{{ .ModuleName }}Repository, client *redis.Client) portOutbound.{{ .ModuleName }}Repository {
	return &cachingRepository{
		inner:  inner,
		client: client,
