	if r.client != nil {
		cached, err := r.client.Get(ctx, cacheKey(id)).Bytes()
		if err == nil {
			var {{ .ModuleNameLower }} entity.{{ .ModuleName }}
			if err := json.Unmarshal(cached, &{{ .ModuleNameLower }}); err == nil {
